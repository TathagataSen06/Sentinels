#!/bin/bash
DIR=$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )
PIDFILE="/var/run/sentinelsd.pid"

cmd=$1

function usage() {
    echo -e "\n  Sentinels\n"
    echo -e "\tsentinelsd [ --start | --dev | --stop | --restart | --copyconfig | --usermodule | --version | --help ] [--uid=nobody] [--gid=nogroup]\n\n"
    echo -e "\t\t--start\tStarts the sentinelsd process"
    echo -e "\t\t--dev\tRun the sentinelsd process in the foreground"
    echo -e "\t\t--stop\tStops the sentinelsd process"
    echo -e "\t\t--usermodule\tRun sentinelsd in foreground with only usermodules enabled"
    echo -e "\t\t--copyconfig\tCreates a default config file at /etc/sentinelsd/sentinels.conf"
    echo -e "\t\t--version\tDisplays the current sentinels version."
    echo -e "\t\t--"
    echo -e "\t\t--help\tThis help\n"
    echo -e "\toptions"
    echo -e "\t\t--allow-run-as-root\tDo not drop privileges of the sentinels once process starts"
    echo -e "\t\t--uid\tSpecify a user or uid to drop privileges to"
    echo -e "\t\t--gid\tSpecify a group of gid to drop privileges to"
}

# Parse options
for arg in "$@"; do
   case $arg in
        --uid=*)
            readonly TWISTD_UID_FLAG=" --uid=${arg#*=}"
            ;;
        --gid=*)
            readonly TWISTD_GID_FLAG=" --gid=${arg#*=}"
            ;;
    esac
done

function warn_drop_privileges {
  if  [[ -z $TWISTD_UID_FLAG || -z $TWISTD_GID_FLAG ]]; then
      echo "WARNING: Sentinels will not drop root user or group privileges after launching. Set both --uid=nobody and --gid=nogroup (or another low privilege user/group) to silence this warning." >&2
  fi
}

# Use sudo when not running as root
function sudo() {
  if [[ "$EUID" -ne 0 ]]; then
    $(which sudo) $*
  else
    # Strip `sudo -E` before running the remaining command
    ${*:2}
  fi
}

if [[ "${cmd}" == "--start" ]]; then
    warn_drop_privileges
    sudo -E "${DIR}/twistd" -y "${DIR}/sentinels.tac" --pidfile "${PIDFILE}" --syslog --prefix=sentinelsd ${TWISTD_UID_FLAG:-} ${TWISTD_GID_FLAG:-}
elif [[ "${cmd}" == "--dev" ]]; then
    warn_drop_privileges
    sudo -E "${DIR}/twistd" -noy "${DIR}/sentinels.tac" --pidfile "${PIDFILE}" ${TWISTD_UID_FLAG:-} ${TWISTD_GID_FLAG:-}
elif [[ "${cmd}" == "--usermodule" ]]; then
  usermodconf=$(python3 -c "from pkg_resources import resource_filename; print(resource_filename('sentinels', 'data/settings-usermodule.json'))")

  if [[ -f sentinels.conf ]]; then
    if ! diff -q sentinels.conf "${usermodconf}" 2>&1 >/dev/null; then
      echo "Backing up old config to ./sentinels.conf.old"
      cp sentinels.conf{,.old}
    fi
  fi

  cp "${usermodconf}" sentinels.conf
  sudo -E "${DIR}/twistd" -noy "${DIR}/sentinels.tac"

elif [[ "${cmd}" == "--restart" ]]; then
    pid=`sudo -E cat "${PIDFILE}"`
    sudo -E kill "$pid"
    warn_drop_privileges
    sudo -E "${DIR}/twistd" -y "${DIR}/sentinels.tac" --pidfile "${PIDFILE}" --syslog --prefix=sentinelsd ${TWISTD_UID_FLAG:-} ${TWISTD_GID_FLAG:-}
elif [[ "${cmd}" == "--stop" ]]; then
    pid=`sudo -E cat "${PIDFILE}"`
    sudo -E kill "$pid"
elif [[ "${cmd}" == "--copyconfig" ]]; then
    if [[ -f /etc/sentinelsd/sentinels.conf ]]; then
        echo "A config file already exists at /etc/sentinelsd/sentinels.conf, please move it first"
        exit 1
    fi
    defaultconf=$(python3 -c "from pkg_resources import resource_filename; print(resource_filename('sentinels', 'data/settings.json'))")
    sudo -E mkdir -p /etc/sentinelsd
    sudo -E cp "${defaultconf}" /etc/sentinelsd/sentinels.conf
    echo -e "[*] A sample config file is ready /etc/sentinelsd/sentinels.conf\n"
    echo    "[*] Edit your configuration, then launch with \"sentinelsd --start\""
elif [[ "${cmd}" == "--version" ]]; then
    python3 -c "from sentinels import __version__; print(__version__);"
else
    usage
    exit 1
fi
