# Docker Compose Environment Configuration
# Copy this file to .env in the infra directory and adjust values as needed

# PostgreSQL Configuration
POSTGRES_USER=sentinels
POSTGRES_PASSWORD=sentinels_password
POSTGRES_DB=sentinels

# Application Configuration
LOG_LEVEL=INFO

# Database Connection (internal Docker network)
DATABASE_URL=postgresql://sentinels:sentinels_password@postgres:5432/sentinels
REDIS_URL=redis://redis:6379/0

# Grafana Configuration
GF_SECURITY_ADMIN_PASSWORD=admin
GF_SECURITY_ADMIN_USER=admin
